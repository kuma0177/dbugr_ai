# Copy to .env in each app that needs it

# packages/db (also used by apps/api, apps/worker, apps/mcp-server)
DATABASE_URL="file:./dev.db"

# apps/api
PORT=3001
WORKER_URL=http://localhost:3002

# apps/worker
PORT=3002

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── AI (apps/worker) ─────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
# If not set, the worker falls back to mock summaries.
ANTHROPIC_API_KEY=

# ── GitHub Issues integration (apps/api) ──────────────────────────────────────
# Create a fine-grained PAT with Issues: Read & Write on the target repo.
GITHUB_TOKEN=
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo

# ── Jira integration (apps/api) ───────────────────────────────────────────────
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=yourteam.atlassian.net
JIRA_EMAIL=you@yourteam.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ

# ── V2: Claude Code Generation (apps/api) ────────────────────────────────────
# For automatic code generation from feedback (V2 feature).
# Claude API key (same as ANTHROPIC_API_KEY, or separate if desired).
CLAUDE_API_KEY=sk-ant-...

# Target repository to receive code changes (where feedback improvements are sent).
# Example: https://github.com/kuma0177/gettwynd
TARGET_REPO_URL=https://github.com/your-org/your-repo
TARGET_REPO_BRANCH=main

# Auto-merge PRs after generation (requires additional setup).
# Set to 'true' to auto-merge, 'false' (default) for manual review.
AUTO_MERGE=false
