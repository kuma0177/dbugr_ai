<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>com.feedbackagent.desktop</string>
  <!-- Required for ScreenCaptureKit / TCC screen capture prompts -->
  <key>NSScreenCaptureUsageDescription</key>
  <string>Dbugr captures only the display or window you pick so you can crop and annotate feedback.</string>
  <!-- Phase 2 web-to-desktop account linking. The web app creates a short-lived
       link code and opens dbugr://link?... so the Mac app can redeem it. -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLName</key>
      <string>com.feedbackagent.desktop.link</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>dbugr</string>
      </array>
    </dict>
  </array>
  <!-- Hide the Dock icon — Dbugr lives exclusively in the menu bar -->
  <key>LSUIElement</key>
  <true/>
</dict>
</plist>
