generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?
  role      String   @default("member")
  createdAt DateTime @default(now())

  feedbackSessions FeedbackSession[]
  comments         FeedbackComment[]
  votes            FeedbackVote[]
  auditLogs        AuditLog[]
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  createdAt    DateTime @default(now())

  projects     Project[]
  integrations Integration[]
  auditLogs    AuditLog[]
}

model Project {
  id                String           @id @default(cuid())
  organizationId    String
  name              String
  slug              String
  repoUrl           String?
  jiraProjectKey    String?
  figmaFileKey      String?
  visibilityDefault String           @default("private")
  createdAt         DateTime         @default(now())

  organization      Organization     @relation(fields: [organizationId], references: [id])
  feedbackSessions  FeedbackSession[]
}

model FeedbackSession {
  id          String   @id @default(cuid())
  projectId   String
  createdBy   String
  title       String
  status      String   @default("draft")
  visibility  String   @default("private")
  videoUrl    String?
  audioUrl    String?
  transcript  String?
  aiSummary   String?
  aiTaskBrief String?
  userIntent  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project           @relation(fields: [projectId], references: [id])
  creator     User              @relation(fields: [createdBy], references: [id])
  frames      FeedbackFrame[]
  comments    FeedbackComment[]
  tasks       ImprovementTask[]
}

model FeedbackFrame {
  id                String   @id @default(cuid())
  feedbackSessionId String
  timestampMs       Int
  imageUrl          String
  cursorX           Float
  cursorY           Float
  clickType         String?
  regionX           Float?
  regionY           Float?
  regionW           Float?
  regionH           Float?
  description       String?

  session           FeedbackSession @relation(fields: [feedbackSessionId], references: [id])
}

model FeedbackComment {
  id                String   @id @default(cuid())
  feedbackSessionId String
  parentCommentId   String?
  authorId          String
  body              String
  visibility        String   @default("public")
  votesCount        Int      @default(0)
  createdAt         DateTime @default(now())

  session     FeedbackSession   @relation(fields: [feedbackSessionId], references: [id])
  author      User              @relation(fields: [authorId], references: [id])
  parent      FeedbackComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies     FeedbackComment[] @relation("CommentReplies")
  votes       FeedbackVote[]
}

model FeedbackVote {
  id               String   @id @default(cuid())
  feedbackCommentId String
  userId           String
  value            Int
  createdAt        DateTime @default(now())

  comment FeedbackComment @relation(fields: [feedbackCommentId], references: [id])
  user    User            @relation(fields: [userId], references: [id])

  @@unique([feedbackCommentId, userId])
}

model ImprovementTask {
  id                String   @id @default(cuid())
  feedbackSessionId String
  title             String
  description       String
  status            String   @default("draft")
  target            String
  externalUrl       String?
  externalId        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  session FeedbackSession @relation(fields: [feedbackSessionId], references: [id])
}

model Integration {
  id                    String   @id @default(cuid())
  organizationId        String
  provider              String
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  configJson            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String
  action         String
  targetType     String
  targetId       String
  metadataJson   String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User         @relation(fields: [actorId], references: [id])
}
