# Copy to `.env` at the repo root
# The API and worker load this file automatically and resolve DATABASE_URL for the local SQLite store.
# This file now includes short setup notes for each key so local setup is less guessy.
# Only fill in the sections needed for the milestone you are working on.

# packages/db (also used by apps/api, apps/worker, apps/mcp-server)
# Local development uses SQLite by default. No external provisioning needed.
DATABASE_URL="file:./packages/db/prisma/dev.db"

# apps/api
# Local API port. Change only if 3001 is already in use.
PORT=3001
# Local worker URL. Keep this aligned with the worker PORT below.
WORKER_URL=http://localhost:3002

# apps/worker
# Local worker port. Change only if 3002 is already in use.
PORT=3002

# apps/web
# Web app uses this to talk to the local API.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Public DMG URL used by the homepage and onboarding download buttons.
# Production example:
# https://github.com/kuma0177/debgr_ai/releases/latest/download/dbugr-ai-0.0.1-macos-aarch64.dmg
NEXT_PUBLIC_MAC_DMG_URL=https://github.com/kuma0177/debgr_ai/releases/download/pre-open-source-ready-stable/dbugr-ai-0.0.1-macos-aarch64.dmg

# Phase 2 endpoint smoke test
# Local example: http://127.0.0.1:3001/api
# Railway example: https://<your-api-service>.up.railway.app/api
PHASE2_API_BASE_URL=http://127.0.0.1:3001/api

# ── AI (apps/worker) ─────────────────────────────────────────────────────────
# Local dev key for Anthropic-powered summaries.
# How to get it:
# 1. Sign in at https://console.anthropic.com/
# 2. Go to Settings -> API Keys
# 3. Create a new key
# 4. Paste it here
# If not set, the worker falls back to mock summaries in some flows.
ANTHROPIC_API_KEY=

# ── GitHub Issues integration (apps/api) ──────────────────────────────────────
# Local/system GitHub token for direct API access.
# How to get it:
# 1. Go to https://github.com/settings/tokens?type=beta
# 2. Create a Fine-grained personal access token
# 3. Scope it to the target repo
# 4. Grant at least Issues: Read and Write
# 5. Paste the token here
# This is for local development or system-owned integrations only, not end-user OAuth.
GITHUB_TOKEN=
# GitHub owner or org for local/test routing, for example `kuma0177`
GITHUB_OWNER=your-org-or-username
# GitHub repo name only, for example `debgr_ai`
GITHUB_REPO=your-repo

# ── Jira integration (apps/api) ───────────────────────────────────────────────
# Optional Jira integration.
# How to get the API token:
# 1. Sign in at https://id.atlassian.com/
# 2. Open Security -> API tokens
# 3. Create a token
# 4. Paste it here
# `JIRA_HOST` should look like `yourteam.atlassian.net`
JIRA_HOST=yourteam.atlassian.net
JIRA_EMAIL=you@yourteam.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ

# ── V2: Claude Code Generation (apps/api) ────────────────────────────────────
# Optional second Anthropic key name used by some app code paths.
# You can usually reuse `ANTHROPIC_API_KEY` here.
# If you want a separate one:
# 1. Create another Anthropic API key in the console
# 2. Paste it here
CLAUDE_API_KEY=sk-ant-...

# Target repository to receive code changes (where feedback improvements are sent).
# Example: https://github.com/kuma0177/gettwynd
TARGET_REPO_URL=https://github.com/your-org/your-repo
TARGET_REPO_BRANCH=main

# Auto-merge PRs after generation (requires additional setup).
# Set to 'true' to auto-merge, 'false' (default) for manual review.
AUTO_MERGE=false

# ── Phase 2: Web auth, orgs, social review, and enterprise-light controls ────
# These are placeholders for the Phase 2 collaboration/IAM plan in
# docs/phase-2-social-refinement-plan.md. Provision only what is needed for the
# milestone being implemented.

# Web app / API public URLs
# `APP_URL` is the main web origin users visit.
# Local dev example: http://localhost:3000
# Production example: https://app.dbugr.ai
# Railway preview example: https://<your-web-service>.up.railway.app
APP_URL=http://localhost:3000
# Public browser-safe copy of `APP_URL`
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Server-side API base URL
# Railway preview example: https://<your-api-service>.up.railway.app/api
API_URL=http://localhost:3001/api

# Auth/session provider
# Choose the provider you are using for the current milestone.
# Example values: `local`, `authjs`, `clerk`, `supabase`
AUTH_PROVIDER=local
# Random secret used to sign auth/session tokens.
# How to generate it:
# `openssl rand -base64 32`
AUTH_SECRET=
# Auth callback base URL, usually the same as APP_URL in local dev.
AUTH_URL=http://localhost:3000

# Dbugr platform-admin emails.
# These users can search across all Dbugr users and organizations in /admin.
# Keep this short and explicit. Example: founder@dbugr.ai,ops@dbugr.ai
DEBUGR_SUPER_ADMIN_EMAILS=

# Google OAuth sign-in
# Needed only if users sign in with Google.
# How to get these:
# 1. Go to https://console.cloud.google.com/
# 2. Create or select a project
# 3. Enable Google Identity / OAuth consent screen
# 4. Create OAuth 2.0 Client Credentials
# 5. Add redirect URIs from your auth provider or app
# 6. Paste the client ID and client secret here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email invites and notifications
# Pick one provider for V1. Resend is usually the simplest.
# Resend setup:
# 1. Go to https://resend.com/
# 2. Create an API key
# 3. Verify your sending domain
# 4. Paste the key into `RESEND_API_KEY`
# Postmark setup:
# 1. Go to https://postmarkapp.com/
# 2. Create a server
# 3. Create a server API token
# 4. Paste it into `POSTMARK_SERVER_TOKEN`
# SendGrid setup:
# 1. Go to https://sendgrid.com/
# 2. Create an API key with Mail Send access
# 3. Paste it into `SENDGRID_API_KEY`
EMAIL_PROVIDER=resend
# From address used for invites and notifications
EMAIL_FROM="Dbugr <notifications@dbugr.ai>"
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
SENDGRID_API_KEY=

# Screenshot/artifact object storage
# Use `local` for local dev at first if you are not yet uploading screenshots.
# Suggested hosted options:
# - AWS S3
# - Cloudflare R2
# - Supabase Storage
# - Vercel Blob
#
# S3/R2 style setup:
# 1. Create a bucket
# 2. Create an access key with read/write access to that bucket
# 3. Paste bucket name, region, access key ID, and secret here
# 4. Set the public base URL or signed asset base URL if applicable
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=
# Public CDN/base URL for publicly viewable sanitized assets
PUBLIC_ASSET_BASE_URL=

# App-managed secrets and desktop account linking
# Used to encrypt app-managed sensitive values such as org credential records.
# How to generate it:
# `openssl rand -base64 32`
APP_ENCRYPTION_KEY=
# Used for desktop device-link tokens between the web app and desktop app.
# How to generate it:
# `openssl rand -base64 32`
DESKTOP_LINK_SECRET=

# OpenAI/Codex API key for validation, AI preflight, or org-managed handoff
# How to get it:
# 1. Sign in at https://platform.openai.com/
# 2. Go to API Keys
# 3. Create a new secret key
# 4. Paste it here
# For solo/local use this can be your own key. Do not treat this as a universal
# customer key store.
OPENAI_API_KEY=

# GitHub OAuth / connected account flow
# Needed only if users connect GitHub accounts through OAuth.
# How to get these:
# 1. Go to https://github.com/settings/developers
# 2. Create a new GitHub OAuth App
# 3. Set Homepage URL to APP_URL
# 4. Set Authorization callback URL to your auth callback route
# 5. Paste the client ID and secret here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public feed moderation and reporting
# `MODERATION_PROVIDER` can be `manual` to start.
# For V1 public feed, manual review plus a reporting inbox may be enough.
# If using an API-based moderation provider:
# - OpenAI moderation can reuse `OPENAI_API_KEY`
# - Or use a separate moderation product/API and place its key here
MODERATION_PROVIDER=
MODERATION_API_KEY=
# Email inbox or alias for abuse reports, public feed reports, and moderation alerts.
# Example: `safety@dbugr.ai` or your own email during MVP.
TRUST_SAFETY_EMAIL=

# Operations
# Optional but recommended once the app is deployed anywhere public.
# Sentry:
# 1. Create a project at https://sentry.io/
# 2. Copy the DSN here
SENTRY_DSN=
# PostHog:
# 1. Create a project at https://posthog.com/
# 2. Copy the project API key here
POSTHOG_KEY=
# Browser-safe copy for client analytics
NEXT_PUBLIC_POSTHOG_KEY=
# Secret for cron jobs or background jobs hitting protected endpoints.
# Generate with: `openssl rand -base64 32`
JOB_SECRET=
# Secret used to verify incoming webhooks from external systems.
# Generate with: `openssl rand -base64 32`
WEBHOOK_SECRET=
