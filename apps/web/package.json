{
  "name": "@feedbackagent/web",
  "version": "0.0.1",
  "scripts": {
    "dev": "rm -rf .next && next dev -p 3000",
    "build": "pnpm --filter @feedbackagent/shared build && DEBUGR_NEXT_DIST_DIR=.next-build next build",
    "start": "DEBUGR_NEXT_DIST_DIR=.next-build next start",
    "test:regression": "node ./scripts/check-dev-build-isolation.mjs && node ./scripts/check-account-navigation.mjs"
  },
  "dependencies": {
    "@feedbackagent/shared": "workspace:*",
    "html2canvas": "^1.4.1",
    "next": "^15.3.0",
    "next-auth": "^4.24.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.4.0"
  }
}
