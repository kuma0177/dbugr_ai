{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "debugr.ai",
  "version": "0.0.1",
  "identifier": "com.feedbackagent.desktop",
  "build": {
    "beforeDevCommand": "pnpm vite --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "pnpm vite build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "debugr.ai",
        "width": 420,
        "height": 460,
        "resizable": false,
        "center": true,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "Debugr Annotation",
        "url": "http://127.0.0.1:5173/overlay.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "width": 2560,
        "height": 1600,
        "x": 0,
        "y": 0
      }
    ]
  },
  "plugins": {
    "global-shortcut": {}
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
