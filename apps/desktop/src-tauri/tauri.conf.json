{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "debugr.ai",
  "version": "0.0.1",
  "identifier": "com.feedbackagent.desktop",
  "build": {
    "beforeDevCommand": "pnpm vite --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "pnpm vite build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "debugr.ai",
        "width": 1280,
        "height": 880,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "Debugr Annotation",
        "url": "overlay.html",
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "backgroundColor": "#00000000",
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "fullscreen": false,
        "width": 1440,
        "height": 900,
        "x": 0,
        "y": 0
      }
    ]
  },
  "plugins": {
    "global-shortcut": null
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/icon.icns"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "infoPlist": "Info.plist",
      "entitlements": "Debugr.entitlements",
      "hardenedRuntime": false
    }
  }
}
